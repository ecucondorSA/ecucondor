# ECUCONDOR - .gitignore

# ===== PYTHON =====
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ===== ENTORNO VIRTUAL =====
venv/
.venv/
ENV/
env/

# ===== VARIABLES DE ENTORNO =====
.env
.env.local
.env.*.local

# ===== CERTIFICADOS (CRÍTICO - NUNCA COMMITEAR) =====
certs/*.p12
certs/*.pfx
certs/*.pem
certs/*.key
certs/*.crt
!certs/.gitkeep
!certs/README.md

# ===== IDE =====
.idea/
.vscode/
*.swp
*.swo
*~

# ===== TESTING =====
.coverage
htmlcov/
.pytest_cache/
.tox/

# ===== LOGS =====
*.log
logs/

# ===== CACHE =====
.cache/
*.cache

# ===== OS =====
.DS_Store
Thumbs.db

# ===== ARCHIVOS TEMPORALES =====
*.tmp
*.temp
tmp/
temp/

# ===== CREDENCIALES Y TOKENS =====
gcp-oauth.keys.json
token.json
*.keys.json
.mcp.json

# ===== CLAUDE =====
.claude/

# ===== DATOS LOCALES =====
data/

# ===== NODE =====
node_modules/

# ===== SUPABASE LOCAL =====
.supabase/

# ===== ARCHIVOS GENERADOS / BINARIOS =====
*.pdf
*.xml
*.zip
*.jpg
*.png
!src/sri/schemas/*.xsd

# ===== REPORTES GENERADOS =====
output/
reportes/
input/

# ===== LEGAL Y PRIVADO =====
legal/
aumento_capital_150k/
*_CONTABILIDAD.md
*.resolved

