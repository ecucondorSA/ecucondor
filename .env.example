# =====================================================
# ECUCONDOR - Variables de Entorno
# Sistema de Contabilidad Automatizada para SAS Ecuador
# =====================================================
# IMPORTANTE: Copiar este archivo a .env y completar los valores
# NUNCA commitear el archivo .env al repositorio

# ===== AMBIENTE =====
ENVIRONMENT=development  # development, staging, production

# ===== SUPABASE =====
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# ===== SRI - FACTURACIÓN ELECTRÓNICA =====
# Ambiente: 1 = Pruebas (celcer.sri.gob.ec), 2 = Producción (cel.sri.gob.ec)
SRI_AMBIENTE=1
SRI_TIPO_EMISION=1

# Certificado de firma electrónica (.p12)
SRI_CERT_PATH=/app/certs/firma.p12
SRI_CERT_PASSWORD=tu_contraseña_del_certificado

# Datos del emisor (SAS)
SRI_RUC=1234567890001
SRI_RAZON_SOCIAL=ECUCONDOR SAS
SRI_NOMBRE_COMERCIAL=ECUCONDOR
SRI_DIRECCION_MATRIZ=Av. Principal 123, Quito, Ecuador
SRI_OBLIGADO_CONTABILIDAD=SI
SRI_CONTRIBUYENTE_ESPECIAL=
SRI_REGIMEN_MICROEMPRESAS=NO
SRI_AGENTE_RETENCION=
SRI_RIMPE=NO

# Establecimiento y punto de emisión
SRI_ESTABLECIMIENTO=001
SRI_PUNTO_EMISION=001

# ===== IESS - CÓDIGO 109 =====
IESS_CODIGO_RELACION=109
IESS_PORCENTAJE_APORTE=17.6
SBU_ACTUAL=460.00

# ===== UAFE - CUMPLIMIENTO ANTI-LAVADO =====
UAFE_UMBRAL_RESU=10000.00
UAFE_DIAS_PLAZO_RESU=15
UAFE_DIAS_PLAZO_ROII=4

# ===== MODELO COMISIONISTA =====
COMISION_PORCENTAJE=1.5
PASIVO_PORCENTAJE=98.5

# ===== IVA =====
IVA_PORCENTAJE=15.0

# ===== EMAIL (opcional) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=ECUCONDOR <noreply@ecucondor.ec>

# ===== LOGGING =====
LOG_LEVEL=INFO
LOG_FORMAT=json
